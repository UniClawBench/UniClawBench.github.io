{
  "display_name": "CollectionBuilder \u2014 Archive",
  "based_on": "https://github.com/CollectionBuilder/collectionbuilder-gh",
  "item_metadata_fields": [
    "title",
    "caption",
    "creator",
    "date",
    "description",
    "credit",
    "rights",
    "rightsstatement_uri",
    "accession_number",
    "subject",
    "format",
    "location"
  ],
  "features": {
    "timeline": true,
    "map": true,
    "iiif_large_images": true,
    "browse_by_filter": true,
    "search": true,
    "responsive": true
  },
  "note": "archival metadata schema from a CSV; rights + rights URI + accession supported; includes a Timeline page",
  "id": "collectionbuilder_archive"
}